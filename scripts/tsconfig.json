{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "types": [
            "node"
        ],
        "noEmit": true,
        "resolveJsonModule": true
    },
    "include": [
        "./**/*.ts",
        "../config/**/*.ts"
    ],
    "exclude": [
        "../node_modules",
        "../dist"
    ]
}