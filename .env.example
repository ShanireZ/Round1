# Round1 minimal environment template
#
# Generate a local file with:
#   npm run env:init -- --profile local --print
#   npm run env:init -- --profile production-runtime --print
#   npm run env:init -- --profile offline-content --print
#
# Code defaults live in config/env.ts. Do not repeat local single-machine defaults here unless
# you are intentionally overriding them for deployment. In particular, Redis, worker, sandbox,
# database pool, session TTL, auth rate-limit, PM2, healthcheck, trust-proxy, dev HTTPS cert,
# autosave, and assignment timing defaults are already provided by code or init scripts.

# Core runtime
NODE_ENV=development
DATABASE_URL=postgres://round1:round1_dev@127.0.0.1:4397/round1
APP_PUBLIC_URL=https://round1.local
APP_API_ORIGIN=https://round1.local

# Secrets
# Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=
TOTP_ENCRYPTION_KEK=

# Optional first admin bootstrap password.
# Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
ROUND1_INITIAL_ADMIN_PASSWORD=

# Mail provider credentials
MAIL_PROVIDER=resend
MAIL_FROM=
RESEND_API_KEY=
# POSTMARK_SERVER_TOKEN=
# TENCENT_SES_SECRET_ID=
# TENCENT_SES_SECRET_KEY=
# TENCENT_SES_REGION=ap-hongkong

# Bot protection
AUTH_TURNSTILE_SITE_KEY=
AUTH_TURNSTILE_SECRET_KEY=

# Third-party identity
CPPLEARN_OIDC_ISSUER=
CPPLEARN_OIDC_CLIENT_ID=
CPPLEARN_OIDC_CLIENT_SECRET=
CPPLEARN_OIDC_REDIRECT_URI=
# QQ_CONNECT_CLIENT_ID=
# QQ_CONNECT_CLIENT_SECRET=
# QQ_CONNECT_REDIRECT_URI=

# Offline content LLM lane. Keep empty on production runtime if no online generation is used.
# Provider base URLs have code defaults; set *_BASE_URL only when overriding a provider endpoint.
LLM_PROVIDER_DEFAULT=
LLM_PROVIDER_BACKUP=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
LLM_REASONING_DEFAULT=
LLM_THINKING_TYPE_DEFAULT=
LLM_THINKING_BUDGET_DEFAULT=
LLM_REASONING_SUMMARY_DEFAULT=

# Public assets
R2_PUBLIC_BASE_URL=

# Optional overrides for non-default topology. Usually leave these out on a single VPS.
# PORT=7654
# ROUND1_BIND_HOST=127.0.0.1
# REDIS_URL=redis://127.0.0.1:4395
# SANDBOX_RUNNER_URL=http://127.0.0.1:4401
# ROUND1_PM2_ENABLE_CONTENT_WORKER=1
