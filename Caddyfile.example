# Round1 生产 Caddy 模板。
#
# 本文件使用 Caddyfile 原生语法，不使用 Caddy JSON 配置格式。
# `format json` 只表示访问日志以 JSON 格式输出。
#
# 部署前请按实际环境修改下列字面量：
# - 站点域名：round1.example.com
# - 前端构建目录：/opt/round1/client/dist
# - Express API：127.0.0.1:7654
# - 访问日志：/var/log/caddy/round1-access.json
# - R2 公开资源源站：https://r2.example.com
#
# 说明：
# - 公网防火墙只开放 Caddy TCP 80/443 与 SSH TCP 9179。
# - 域名站点会让 Caddy 自动 HTTPS 机制处理 HTTP 到 HTTPS 跳转。
# - Caddy 默认协议为 h1/h2/h3；保留 h1，因为当前 h2 仍需要 h1 支持。
# - 如果保留默认 HTTP/3，还需要允许 UDP 443。
# - Express 必须保持 ROUND1_BIND_HOST=127.0.0.1 且 PORT=7654。
# - Postgres 4397 与 Redis 4395 不得暴露公网。

https://round1.example.com {
	root * /opt/round1/client/dist
	encode zstd gzip

	tls {
		protocols tls1.2 tls1.3
	}

	log {
		output file /var/log/caddy/round1-access.json {
			roll_size 100MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}

	header {
		-Server
		Strict-Transport-Security "max-age=31536000"
		Content-Security-Policy "default-src 'self'; script-src 'self' https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com; connect-src 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	# 动态 API 交给 Node；API 响应缓存语义由 Express 决定，不在 Caddy 层统一缓存。
	@api path /api/*
	handle @api {
		reverse_proxy 127.0.0.1:7654 {
			header_up X-Real-IP {remote_host}
		}
	}

	# 运行时资源代理。R2 源站应提供 /font/* 与 /logo/* 路径；
	# 浏览器只加载同源资源 URL，避免 CORS 漂移。
	@fonts path /font/*
	handle @fonts {
		header Cache-Control "public, max-age=86400"
		reverse_proxy https://r2.example.com {
			header_up Host {upstream_hostport}
		}
	}

	@logos path /logo/*
	handle @logos {
		header Cache-Control "public, max-age=86400"
		reverse_proxy https://r2.example.com {
			header_up Host {upstream_hostport}
		}
	}

	# Vite 会把带哈希的构建产物输出到 /assets/。当前先使用一个月保守长缓存；
	# 发布纪律稳定后可提升到一年。
	@hashedAssets path_regexp hashedAssets ^/assets/.+-[A-Za-z0-9_-]+\.(?:css|js|mjs|map|woff2?|ttf|otf|png|jpe?g|webp|avif|svg|ico)$
	header @hashedAssets Cache-Control "public, max-age=2592000, immutable"

	# 未带哈希的静态资源可能原名更新，因此只缓存一天。
	@staticAssets path /favicon.svg /robots.txt /site.webmanifest /manifest.webmanifest /logos/* /fonts/* /logo/*
	header @staticAssets Cache-Control "public, max-age=86400"

	route {
		try_files {path} /index.html

		# SPA 入口、路由回退和关键易更新内容每次导航都必须重新验证。
		header /index.html Cache-Control "no-cache, no-store, max-age=0, must-revalidate"

		file_server
	}
}
