{
  "name": "round1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "算法竞赛测试平台",
  "workspaces": [
    "server",
    "client"
  ],
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.1"
  },
  "scripts": {
    "clean": "tsx scripts/maintenance.ts clean-build-output dist/server client/dist client/tsconfig.tsbuildinfo",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "bundle:questions": "tsx scripts/questionBundle.ts",
    "bundle:prebuilt-papers": "tsx scripts/prebuiltPaperBundle.ts",
    "dev:setup": "tsx scripts/maintenance.ts dev-setup",
    "env:init": "tsx scripts/maintenance.ts init-env",
    "init:admin": "tsx scripts/maintenance.ts init-admin",
    "healthcheck": "tsx scripts/maintenance.ts healthcheck",
    "migrate": "tsx scripts/maintenance.ts migrate",
    "migrate:up": "tsx scripts/maintenance.ts migrate up",
    "migrate:down": "tsx scripts/maintenance.ts migrate down",
    "migrate:status": "tsx scripts/maintenance.ts migrate status",
    "import:questions:2026": "tsx scripts/questionBundle.ts import-batch",
    "inventory:questions": "tsx scripts/audit.ts report-question-inventory --out-dir count/state",
    "count:questions": "tsx scripts/audit.ts report-question-counts",
    "inventory:papers": "tsx scripts/audit.ts report-papers-inventory",
    "inventory:docs": "tsx scripts/audit.ts report-docs-inventory",
    "migrate:rehearse:paper-slot-points-failure": "tsx scripts/maintenance.ts rehearse-paper-slot-points-migration-failure",
    "verify:offline-artifacts": "tsx scripts/audit.ts verify-offline-artifacts",
    "verify:ui-tokens": "tsx scripts/audit.ts verify-ui-tokens",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:scripts": "tsx scripts/tests/bundleCli.test.ts && tsx scripts/tests/questionDiversity.test.ts && tsx scripts/tests/externalLlmDisclosure.test.ts && tsx scripts/tests/scriptConversation.test.ts && tsx scripts/tests/scriptLlmClient.test.ts",
    "client:test": "vitest run -c client/vitest.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "otpauth": "^9.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
