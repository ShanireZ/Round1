{
  "name": "round1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "算法竞赛测试平台",
  "workspaces": [
    "server",
    "client"
  ],
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.1"
  },
  "scripts": {
    "clean": "tsx scripts/clean-build-output.ts dist/server client/dist client/tsconfig.tsbuildinfo",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "bundle:questions": "tsx scripts/questionBundle.ts",
    "bundle:prebuilt-papers": "tsx scripts/prebuiltPaperBundle.ts",
    "dev:setup": "tsx scripts/dev-setup.ts",
    "env:init": "tsx scripts/initEnv.ts",
    "init:admin": "tsx scripts/initAdmin.ts",
    "healthcheck": "tsx scripts/healthcheck.ts",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:up": "tsx scripts/migrate.ts up",
    "migrate:down": "tsx scripts/migrate.ts down",
    "migrate:status": "tsx scripts/migrate.ts status",
    "import:questions:2026": "tsx scripts/questionBundle.ts import-batch",
    "inventory:questions": "tsx scripts/reportQuestionInventory.ts",
    "inventory:papers": "tsx scripts/reportPapersInventory.ts",
    "inventory:docs": "tsx scripts/reportDocsInventory.ts",
    "migrate:rehearse:paper-slot-points-failure": "tsx scripts/rehearsePaperSlotPointsMigrationFailure.ts",
    "verify:offline-artifacts": "tsx scripts/verifyOfflineArtifactNames.ts",
    "verify:ui-tokens": "tsx scripts/verifyUiTokenUsage.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "client:test": "vitest run -c client/vitest.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "otpauth": "^9.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
