{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "rootDir": "..",
        "outDir": "../dist/server",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": [
        "./**/*.ts",
        "../config/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "__tests__"
    ]
}
