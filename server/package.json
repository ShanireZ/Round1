        "@openrouter/ai-sdk-provider": "^2.8.0",
        "@sentry/node": "^9.15.0",
        "@simplewebauthn/server": "^13.1.1",
        "@types/zxcvbn": "^4.4.5",
        "ai": "^6.0.168",
        "argon2": "^0.41.1",
        "bullmq": "^5.52.2",
