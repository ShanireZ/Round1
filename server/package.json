{
    "name": "server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=24.15.0",
        "npm": ">=11.12.1"
    },
    "scripts": {
        "clean": "tsx ../scripts/clean-build-output.ts ../dist/server",
        "dev": "tsx watch --clear-screen=false index.ts",
        "build": "npm run clean && tsc",
        "start": "node dist/index.js",
        "migrate": "tsx ../scripts/migrate.ts",
        "migrate:up": "tsx ../scripts/migrate.ts up",
        "migrate:down": "tsx ../scripts/migrate.ts down",
        "migrate:status": "tsx ../scripts/migrate.ts status"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.71",
        "@ai-sdk/google": "^3.0.64",
        "@ai-sdk/openai": "^3.0.53",
        "@ai-sdk/openai-compatible": "^2.0.41",
        "@ai-sdk/xai": "^3.0.83",
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@openrouter/ai-sdk-provider": "^2.8.1",
        "@sentry/node": "^10.50.0",
        "@simplewebauthn/server": "^13.3.0",
        "@types/zxcvbn": "^4.4.5",
        "ai": "^6.0.168",
        "argon2": "^0.44.0",
        "bullmq": "^5.76.2",
        "connect-redis": "^9.0.0",
        "csrf-sync": "^4.2.1",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.4.1",
        "express-session": "^1.19.0",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "nodemailer": "^8.0.7",
        "openid-client": "^6.8.3",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "rate-limit-redis": "^4.3.1",
        "redis": "^5.12.1",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6",
        "zxcvbn": "^4.4.2"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/node": "^25.6.0",
        "@types/nodemailer": "^8.0.0",
        "@types/pg": "^8.20.0",
        "@types/swagger-ui-express": "^4.1.8",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
